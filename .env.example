# =============================================================================
# Kingswell Estate Agents — Environment Variables
# Copy to .env.local for local development
# =============================================================================

# --- MongoDB (primary database) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/kingswell

# --- Admin panel: /kingswell-admin ---
ADMIN_EMAIL=admin@kingswell.com
ADMIN_PASSWORD=your_secure_password
# Generate: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# --- Site (public) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Kingswell Estate Agents
NEXT_PUBLIC_PHONE=02080643668
NEXT_PUBLIC_EMAIL=sales@kingswellestateagents.co.uk
NEXT_PUBLIC_WHATSAPP=447367087204

# --- Lead capture ---
LEADS_EMAIL=sales@kingswellestateagents.co.uk
RESEND_API_KEY=

# --- CRM: Alto | Reapit | Street ---
CRM_PROVIDER=alto
CRM_API_KEY=
CRM_WEBHOOK_URL=

# --- Property feed (Rightmove / Zoopla / OTM) ---
PROPERTY_FEED_URL=
PROPERTY_FEED_API_KEY=

# --- Cloudinary (image uploads — admin + website) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Gemini (website chatbot) ---
GEMINI_API_KEY=
# Flash model (default: gemini-2.5-flash). Avoid gemini-2.0-flash if you see quota errors.
GEMINI_MODEL=gemini-2.5-flash

# --- Optional ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_REVIEWS_EMBED_URL=
NEXT_PUBLIC_INSTAGRAM_USERNAME=kingswellagents
